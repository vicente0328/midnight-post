rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             data.createdAt is timestamp;
    }

    function isValidEntry(data) {
      return hasOnlyAllowedFields(['uid', 'content', 'emotion', 'createdAt', 'status']) &&
             data.uid is string && data.uid.size() > 0 &&
             validStringLength('content', 1, 1000) &&
             (!('emotion' in data) || (data.emotion is string && data.emotion.size() <= 50)) &&
             data.createdAt is timestamp &&
             data.status in ['pending', 'replied'];
    }

    function isValidReply(data) {
      return hasOnlyAllowedFields(['uid', 'entryId', 'mentorId', 'quote', 'source', 'translation', 'advice', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.entryId is string && data.entryId.size() > 0 &&
             data.mentorId in ['hyewoon', 'benedicto', 'theodore', 'yeonam'] &&
             validStringLength('quote', 1, 2000) &&
             (!('source' in data) || validStringLength('source', 1, 500)) &&
             validStringLength('translation', 1, 2000) &&
             validStringLength('advice', 1, 10000) &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /entries/{entryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidEntry(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidEntry(request.resource.data) && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /replies/{replyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidReply(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidReply(request.resource.data) && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
