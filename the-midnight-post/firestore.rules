rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'createdAt', 'onboarded']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             data.createdAt is timestamp &&
             (!('onboarded' in data) || data.onboarded is bool);
    }

    function isValidEntry(data) {
      return hasOnlyAllowedFields(['uid', 'content', 'emotion', 'createdAt', 'status']) &&
             data.uid is string && data.uid.size() > 0 &&
             validStringLength('content', 1, 1000) &&
             (!('emotion' in data) || (data.emotion is string && data.emotion.size() <= 50)) &&
             data.createdAt is timestamp &&
             data.status in ['pending', 'replied'];
    }

    function isValidReply(data) {
      return hasOnlyAllowedFields(['uid', 'entryId', 'mentorId', 'quote', 'source', 'translation', 'advice', 'createdAt', 'deliverAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.entryId is string && data.entryId.size() > 0 &&
             data.mentorId in ['hyewoon', 'benedicto', 'theodore', 'yeonam'] &&
             validStringLength('quote', 1, 2000) &&
             (!('source' in data) || validStringLength('source', 1, 500)) &&
             validStringLength('translation', 1, 2000) &&
             validStringLength('advice', 1, 10000) &&
             data.createdAt is timestamp &&
             (!('deliverAt' in data) || data.deliverAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /entries/{entryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidEntry(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidEntry(request.resource.data) && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /replies/{replyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidReply(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidReply(request.resource.data) && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    // 책갈피 — 본인 데이터만 접근 (doc ID: uid_entryId_mentorId)
    match /bookmarks/{bookmarkId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && uidUnchanged() &&
                    request.resource.data.entryId is string &&
                    request.resource.data.mentorId in ['hyewoon', 'benedicto', 'theodore', 'yeonam'];
      allow update: if isAuthenticated() && uidNotModified() &&
                    request.resource.data.entryId is string &&
                    request.resource.data.mentorId in ['hyewoon', 'benedicto', 'theodore', 'yeonam'];
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // 현자 지식 DB — 모든 인증 유저가 읽기 가능, 쓰기는 인증 유저만
    match /mentor_knowledge/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 일일 생성 잠금 메타 — 인증 유저만 읽기/쓰기
    match /meta/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 담소 세션 — 본인 데이터만 접근
    match /damso_sessions/{sessionId} {
      allow get: if isDocOwner();
      // list 쿼리: where('uid','==',user.uid) 패턴을 명시적으로 허용
      allow list: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && uidUnchanged() &&
                    request.resource.data.entryId is string &&
                    request.resource.data.mentorId in ['hyewoon', 'benedicto', 'theodore', 'yeonam'];
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }

    // 담소 메시지 — 본인 데이터만 접근
    match /damso_messages/{messageId} {
      allow get: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && uidUnchanged() &&
                    request.resource.data.sessionId is string &&
                    request.resource.data.type in ['stage_direction', 'mentor', 'user'] &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() <= 5000 &&
                    request.resource.data.order is number &&
                    request.resource.data.createdAt is timestamp;
      allow delete: if isDocOwner();
    }
  }
}
